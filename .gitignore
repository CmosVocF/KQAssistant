# Gradle files
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# Local configuration file (sdk path, etc)
local.properties

# Android Studio / IntelliJ
.idea/
*.iml
*.ipr
*.iws
misc.xml
deploymentTargetDropDown.xml
render.experimental.xml

# Keystore files (do not commit signing keys)
*.jks
*.keystore

# OS files
.DS_Store
Thumbs.db

# Log files
*.log

# APK outputs (keep build outputs out of repo; attach to releases instead)
*.apk
*.ap_
*.aab

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild
.cxx/

# Node / JS (if any)
node_modules/

# Temporary files
*.tmp
*.swp
*~
